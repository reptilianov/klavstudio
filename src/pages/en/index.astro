---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getTranslations } from '../../i18n';

const t = getTranslations('en');
---

<BaseLayout locale="en">
  <section class="hero">
    <div class="container">
      <h1 class="hero-title char-reveal-wrap">{t.hero.title}</h1>
      <p class="hero-subtitle scroll-fade">{t.hero.subtitle}</p>
    </div>
  </section>

  <section id="projects" class="projects">
    <div class="container">
      <h2 class="section-title scroll-fade">{t.projects.title}</h2>

      <div class="project-grid">
        <article class="project-card scroll-fade delay-1">
          <h3 class="project-title">{t.projects.melektausverso.title}</h3>
          <div class="project-content">
            <div class="project-part">
              <h4>Problem</h4>
              <p>{t.projects.melektausverso.problem}</p>
            </div>
            <div class="project-part">
              <h4>System</h4>
              <p>{t.projects.melektausverso.system}</p>
            </div>
            <div class="project-part">
              <h4>Result</h4>
              <p>{t.projects.melektausverso.result}</p>
            </div>
          </div>
        </article>

        <article class="project-card scroll-fade delay-2">
          <h3 class="project-title">{t.projects.horror.title}</h3>
          <div class="project-content">
            <div class="project-part">
              <h4>Problem</h4>
              <p>{t.projects.horror.problem}</p>
            </div>
            <div class="project-part">
              <h4>System</h4>
              <p>{t.projects.horror.system}</p>
            </div>
            <div class="project-part">
              <h4>Result</h4>
              <p>{t.projects.horror.result}</p>
            </div>
          </div>
        </article>

        <article class="project-card scroll-fade delay-3">
          <h3 class="project-title">{t.projects.powerpoint.title}</h3>
          <div class="project-content">
            <div class="project-part">
              <h4>Problem</h4>
              <p>{t.projects.powerpoint.problem}</p>
            </div>
            <div class="project-part">
              <h4>System</h4>
              <p>{t.projects.powerpoint.system}</p>
            </div>
            <div class="project-part">
              <h4>Result</h4>
              <p>{t.projects.powerpoint.result}</p>
            </div>
          </div>
        </article>

        <article class="project-card scroll-fade delay-4">
          <h3 class="project-title">{t.projects.ui.title}</h3>
          <div class="project-content">
            <div class="project-part">
              <h4>Problem</h4>
              <p>{t.projects.ui.problem}</p>
            </div>
            <div class="project-part">
              <h4>System</h4>
              <p>{t.projects.ui.system}</p>
            </div>
            <div class="project-part">
              <h4>Result</h4>
              <p>{t.projects.ui.result}</p>
            </div>
          </div>
        </article>
      </div>
    </div>
  </section>

  <section id="think" class="think">
    <div class="container">
      <h2 class="section-title scroll-fade">{t.think.title}</h2>
      <p class="think-intro scroll-fade">{t.think.intro}</p>

      <div class="think-grid">
        {t.think.items.map((item: any, i: number) => (
          <div class={`think-card scroll-fade delay-${i + 1}`}>
            <h3 class="think-heading">{item.heading}</h3>
            <p>{item.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section id="services" class="services">
    <div class="container">
      <h2 class="section-title scroll-fade">{t.services.title}</h2>
      <p class="services-intro scroll-fade">{t.services.intro}</p>

      <div class="services-grid">
        {t.services.items.map((item: any, i: number) => (
          <div class={`service-card scroll-fade delay-${i + 1}`}>
            <h3 class="service-title">{item.title}</h3>
            <p class="service-desc">{item.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section id="contact" class="contact">
    <div class="container">
      <h2 class="section-title scroll-fade">{t.contact.title}</h2>
      <p class="contact-intro scroll-fade">{t.contact.intro}</p>

      <div class="contact-links scroll-fade">
        <a href="mailto:hello@klav.design" class="contact-link">
          <span class="contact-label">{t.contact.email}</span>
          <span class="contact-value">hello@klav.design</span>
        </a>
        <a href="https://wa.me/1234567890" class="contact-link">
          <span class="contact-label">{t.contact.whatsapp}</span>
          <span class="contact-value">+1 (234) 567-890</span>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

