---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getTranslations } from '../i18n';

const t = getTranslations('en');
---

<BaseLayout locale="en" title="Contact" description="Start a project. Brand design, UX/UI, prototyping, automation, AI-assisted content. Let's talk.">
  <section class="page-hero">
    <div class="container">
      <h1>{t.contact.title}</h1>
      <p class="page-intro">{t.contact.intro}</p>
    </div>
  </section>

  <section class="contact-form-section">
    <div class="container">
      <form class="contact-form" action="https://formspree.io/f/your-form-id" method="POST">
        <div class="form-row">
          <div class="form-group">
            <label for="name">{t.contact.form.name}</label>
            <input type="text" id="name" name="name" required />
          </div>
          <div class="form-group">
            <label for="email">{t.contact.form.email}</label>
            <input type="email" id="email" name="email" required />
          </div>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label for="company">{t.contact.form.company}</label>
            <input type="text" id="company" name="company" />
          </div>
          <div class="form-group">
            <label for="website">{t.contact.form.website}</label>
            <input type="url" id="website" name="website" placeholder="https://" />
          </div>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label for="type">{t.contact.form.type}</label>
            <select id="type" name="type" required>
              <option value="">Select...</option>
              {t.contact.types.map((opt: string) => <option value={opt}>{opt}</option>)}
            </select>
          </div>
          <div class="form-group">
            <label for="budget">{t.contact.form.budget}</label>
            <select id="budget" name="budget">
              <option value="">Select...</option>
              {t.contact.budgets.map((opt: string) => <option value={opt}>{opt}</option>)}
            </select>
          </div>
        </div>

        <div class="form-group">
          <label for="startDate">{t.contact.form.startDate}</label>
          <input type="text" id="startDate" name="startDate" placeholder="e.g., Q3 2026, ASAP, Flexible" />
        </div>

        <div class="form-group">
          <label for="message">{t.contact.form.message}</label>
          <textarea id="message" name="message" rows="6" required></textarea>
        </div>

        <button type="submit" class="btn">{t.contact.form.submit}</button>
      </form>
    </div>
  </section>

  <section class="contact-direct">
    <div class="container">
      <h2>Or reach me directly</h2>
      <div class="contact-links">
        <a href="mailto:hello@klav.design" class="contact-link">
          <span class="contact-label">{t.contact.email}</span>
          <span class="contact-value">hello@klav.design</span>
        </a>
        <a href={t.contact.behanceUrl} class="contact-link" target="_blank">
          <span class="contact-label">{t.contact.behance}</span>
          <span class="contact-value">behance.net/cesarfernando</span>
        </a>
        <a href={t.contact.dribbbleUrl} class="contact-link" target="_blank">
          <span class="contact-label">{t.contact.dribbble}</span>
          <span class="contact-value">dribbble.com/cesarfernando</span>
        </a>
        <a href={t.contact.linkedinUrl} class="contact-link" target="_blank">
          <span class="contact-label">{t.contact.linkedin}</span>
          <span class="contact-value">linkedin.com/in/cesarfernando</span>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>