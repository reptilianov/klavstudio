---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout locale="en" title="Tito's Custom Buckles">
  <section class="project-hero"><div class="hero-bg" style="background:linear-gradient(135deg,#1a1a1a,#2d1810,#1a1a1a)"></div><div class="hero-overlay"></div>
    <div class="container"><div class="hero-content"><a href="/#results" class="back-link"><svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M15 5L5 10L15 15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>Back</a><h1 class="project-title">Tito's Buckles</h1><p class="project-tagline">Western heritage craftsmanship</p><p class="project-context">Craft / E-commerce — USA</p></div></div>
  </section>
  <section class="project-section"><div class="container"><span class="section-label-text"><i>01</i> Problem</span><p class="project-body">Handcrafted buckles needing premium positioning without losing their workshop essence. Top-quality products that needed a brand matching their craftsmanship level.</p></div></section>
  <section class="project-section-alt"><div class="container"><span class="section-label-text"><i>02</i> System</span><p class="project-body">Brand identity with modern precision honoring traditional craftsmanship. Deliberate restraint: the craft speaks louder than the branding.</p></div></section>
  <section class="project-result"><div class="container"><div class="result-box"><h2>Result</h2><p>Premium brand identity that respects and elevates handcrafted work. Visual presence communicating quality without shouting.</p></div></div></section>
</BaseLayout>