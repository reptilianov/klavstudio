---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout locale="en" title="Arte Arabia">
  <section class="project-hero"><div class="hero-bg" style="background:linear-gradient(135deg,#1a1a2e,#16213e,#0f3460)"></div><div class="hero-overlay"></div>
    <div class="container"><div class="hero-content"><a href="/#results" class="back-link"><svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M15 5L5 10L15 15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>Back</a><h1 class="project-title">Arte Arabia</h1><p class="project-tagline">Cultural bridge through design</p><p class="project-context">Art / Cultural Platform</p></div></div>
  </section>
  <section class="project-section"><div class="container"><span class="section-label-text"><i>01</i> Problem</span><p class="project-body">Art platform needing to build cultural bridges through its visual identity. The challenge was creating a system honoring Arab artistic heritage without falling into visual stereotypes.</p></div></section>
  <section class="project-section-alt"><div class="container"><span class="section-label-text"><i>02</i> System</span><p class="project-body">Elegant system honoring heritage while embracing contemporary. Fusion of traditional artistic elements with modern digital presentation.</p></div></section>
  <section class="project-result"><div class="container"><div class="result-box"><h2>Result</h2><p>Cultural identity celebrating artistic traditions without feeling dated or stereotyped. A platform communicating depth and respect for its heritage.</p></div></div></section>
</BaseLayout>