import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout locale="en" title="MindSherpa">
  <section class="project-hero"><div class="hero-bg" style="background-image:url('/projects/mindsherpa/Book-Cover-Design.jpg')"></div><div class="hero-overlay"></div>
    <div class="container"><div class="hero-content"><a href="/#results" class="back-link"><svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M15 5L5 10L15 15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>Back</a><h1 class="project-title">MindSherpa</h1><p class="project-tagline">Visual system for editorial series</p><p class="project-context">Publishing — USA</p></div></div>
  </section>
  <section class="project-section"><div class="container"><span class="section-label-text"><i>01</i> Problem</span><p class="project-body">Publisher needing a distinct identity in a crowded market. Required a visual system for specialized editorial series positioning MindSherpa as the thinking person's publisher.</p></div></section>
  <section class="project-section-alt"><div class="container"><span class="section-label-text"><i>02</i> System</span><p class="project-body">Brand system with distinctive cover designs for multiple series: EDC, HE, and UAP editions. Each series maintains its identity while sharing visual markers across the brand.</p></div></section>
  <section class="project-gallery"><div class="container"><img src="/projects/mindsherpa/Book-Cover-Design_EDC.jpg"/><img src="/projects/mindsherpa/Book-Cover-Design_HE.jpg" class="mt-4"/><img src="/projects/mindsherpa/Book-Cover-Design_UAP.jpg" class="mt-4"/></div></section>
  <section class="project-result"><div class="container"><div class="result-box"><h2>Result</h2><p>Distinctive identity communicating intellectual depth across all series. Flexible system allowing new launches without losing visual coherence.</p></div></div></section>
</BaseLayout>