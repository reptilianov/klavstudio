---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout locale="en" title="Babylon">
  <section class="project-hero"><div class="hero-bg" style="background:linear-gradient(135deg,#1a1a2e,#16213e,#0f3460)"></div><div class="hero-overlay"></div>
    <div class="container"><div class="hero-content"><a href="/#results" class="back-link"><svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M15 5L5 10L15 15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>Back</a><h1 class="project-title">The Last Star of Babylon</h1><p class="project-tagline">Mythological venue experience</p><p class="project-context">Entertainment / Cultural Venue</p></div></div>
  </section>
  <section class="project-section"><div class="container"><span class="section-label-text"><i>01</i> Problem</span><p class="project-body">Creating a cultural landmark identity for a unique venue. The space needed a visual narrative separating it from generic entertainment offerings.</p></div></section>
  <section class="project-section-alt"><div class="container"><span class="section-label-text"><i>02</i> System</span><p class="project-body">Mythological visual system with historical depth. Built a visual narrative rooted in ancient Babylon as a conceptual starting point, translated to contemporary visual language.</p></div></section>
  <section class="project-result"><div class="container"><div class="result-box"><h2>Result</h2><p>Atmospheric identity connecting past and present. The venue gained a distinctive visual presence separating it from generic entertainment.</p></div></div></section>
</BaseLayout>