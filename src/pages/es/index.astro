---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getTranslations } from '../../i18n';

const t = getTranslations('es');

const projectThumbs = {
	okhosting: '/siteimages/Okhosting.webp',
	firstchoice: '/siteimages/firstchoice.webp',
	caintra: '/siteimages/caintra.webp',
	mindsherpa: '/siteimages/mindsherpa.webp',
	airtm: '/siteimages/airtm.webp',
	artearabia: '/siteimages/artearabia.webp',
	babilonia: '/siteimages/babilonia.webp',
	steps: '/siteimages/steps.webp',
};

const galleryKeys = ['okhosting', 'firstchoice', 'caintra', 'mindsherpa', 'airtm', 'artearabia', 'steps'];
---

<BaseLayout locale="es">
	<!-- HERO -->
	<section class="hero">
		<div class="container">
			<h1 class="hero-title">{t.hero.headline}</h1>
			<p class="hero-subtitle scroll-fade">{t.hero.subtitle}</p>
			<div class="hero-cta">
				<a
					href="mailto:cefev.diseno@gmail.com"
					class="btn"
					>{t.hero.cta}</a
				>
			</div>
		</div>
	</section>

	<!-- MASONRY GALLERY -->
	<section class="project-masonry">
		<div class="container">
			<h2 class="section-title scroll-fade">Proyectos</h2>
		</div>
		<div class="masonry-grid">
			{
				galleryKeys.map((key, i) => (
					<a
						href={`/es/project/${key}`}
						class="masonry-item scroll-fade"
						style={`transition-delay: ${i * 0.05}s`}>
						<img
							src={projectThumbs[key]}
							alt={t.projects[key]?.title || key}
							loading="lazy"
						/>
						<div class="masonry-overlay">
							<span class="masonry-title">{t.projects[key]?.title || key}</span>
							<span class="masonry-tagline">{t.projects[key]?.tagline || ''}</span>
						</div>
					</a>
				))
			}
		</div>
	</section>

	<!-- SERVICES -->
	<section
		id="services"
		class="home-services">
		<div class="container">
			<h2 class="section-title scroll-fade">{t.services.title}</h2>
			<p class="section-intro scroll-fade">{t.services.intro}</p>
			<div class="home-services-grid">
				{
					t.services.items.map((svc: any, i: number) => (
						<div
							class="home-service-card scroll-fade"
							style={`transition-delay: ${i * 0.1}s`}>
							<h3>{svc.name}</h3>
							<p>{svc.short}</p>
							<span class="service-price">{svc.price}</span>
						</div>
					))
				}
			</div>
			<div class="section-cta">
				<a
					href="/es/servicios"
					class="btn"
					>Ver servicios completos</a
				>
			</div>
		</div>
	</section>

	<!-- RESULTS -->
	<section
		id="results"
		class="home-results">
		<div class="container">
			<h2 class="section-title scroll-fade">{t.results.title}</h2>
			<p class="section-intro scroll-fade">{t.results.intro}</p>
			<div class="results-list">
				{
					t.results.items.map((item: any, i: number) => (
						<div
							class="result-card scroll-fade"
							style={`transition-delay: ${i * 0.15}s`}>
							<h3>{item.client}</h3>
							<div class="result-body">
								<div class="result-col">
									<span class="result-label">Problema</span>
									<p>{item.problem}</p>
								</div>
								<div class="result-col">
									<span class="result-label">Lo que hice</span>
									<p>{item.result}</p>
								</div>
							</div>
							<div class="result-metrics">
								<span class="result-label">Resultado</span>
								<p>{item.metrics}</p>
							</div>
						</div>
					))
				}
			</div>
		</div>
	</section>

	<!-- ABOUT -->
	<section
		id="about"
		class="home-about">
		<div class="container">
			<h2 class="section-title scroll-fade">{t.about.headline}</h2>
			<div class="about-text scroll-fade">
				<p>{t.about.body1}</p>
				<p>{t.about.body2}</p>
				<p>{t.about.body3}</p>
				<p>{t.about.body4}</p>
			</div>
		</div>
	</section>

	<!-- PROCESS -->
	<section
		id="process"
		class="home-process">
		<div class="container">
			<h2 class="section-title scroll-fade">{t.process.title}</h2>
			<p class="section-intro scroll-fade">{t.process.intro}</p>
			<div class="process-grid">
				{
					t.process.stages.map((stage: any, i: number) => (
						<div
							class="process-step scroll-fade"
							style={`transition-delay: ${i * 0.1}s`}>
							<span class="step-number">{stage.step}</span>
							<h3>{stage.name}</h3>
							<p>{stage.desc}</p>
						</div>
					))
				}
			</div>
		</div>
	</section>

	<!-- CTA FINAL -->
	<section
		id="contact"
		class="home-cta">
		<div class="container">
			<h2 class="scroll-fade">{t.contact.title}</h2>
			<p class="scroll-fade">{t.contact.intro}</p>
			<a
				href="mailto:cefev.diseno@gmail.com"
				class="btn btn-large"
				>{t.contact.emailLabel}</a
			>
		</div>
	</section>
</BaseLayout>
